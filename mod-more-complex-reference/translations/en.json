	// option
	"synced.option.title": "<header>Resynced Settings</>",
	"synced.option.titlet": "Welcome to Resynced ! A mod that extend the base game with functionality and option through configurable module.\n\nTo see settings, you need to start a game with the mod enabled.\nAlso on multiplayer game, only host can see and change settings.",
	"synced.option.languages": "<gl>Languages :</>",
	"synced.option.languagest": "Only <bl>English</> and <bl>French</> are officially translated.\n<rl>Important :</> <hl>Resynced</> use 'id' instead of 'string' for translation, meaning all languages use <bl>English</> text as default to avoid missing string !",
	"synced.option.content": "<gl>Content :</>",
	"synced.option.contentt": "- <bl>Bot Speed</>, allow you to increase the speed of your bots.\n- <bl>Bug Wave</>, wich add a custom bug invasion and event.\n- <bl>Energy Manager</>, allow you to change power production and transfer range.\n- <bl>Fast Production</>, increase the speed of all production and research.\n- <bl>Infinite Resource Node</>, allow you to use resource node forever.\n- <bl>Mining Upgrade</>, increase mining efficiency and range.\n- <bl>Puzzle Hacker</>, add an item to bypass minigames.\n- <bl>Better Stack</>, allow you to increase all stack size.\n- <bl>Custom UI</>, A rework of in game UI, smaller and compact. <rl>WIP</>\n<rl>Content has changed and contain a lot more content, meaning this part will be rewrite soon to be more explicit.</>",
	"synced.option.warn": "<gl>Compatibility :</>",
	"synced.option.warnt": "<hl>Resynced is save safe and can be enabled, disabled, removed or added at any time. ( Any Resynced items / frames / techs will be removed by the game )</>",
	
	// ui
	"synced.ui.help": "- Each modules will start disabled.\n- Mouse hover over elements to see tooltips.\n- The button <gl>Apply Changes</> isn't required, it's just faster, if you don't use it then you must save and raload yourself to apply changes !\n- To add a translation, please refer to <gl>'Resynced/translations/en.json'</>.\n- To add your own mod option in <hl>Resynced</>, please refer to <gl>'Resynced/ModSample.zip'</>.",
	"synced.ui.apply": "Apply Changes",
	"synced.ui.applyt": "It will create a temporary save ( named <gl>'Resynced_TEMP'</> ) and load it to apply your settings.",
